{
  "defaultProvider": "qwen",
  "requestTimeoutMs": 90000,
  "maxInputChars": {
    "text": 400,
    "htmlSnippet": 600,
    "interactiveHtml": 2400,
    "metaDescription": 300,
    "firstH1": 120,
    "title": 120
  },
  "providers": {
    "mock": {
      "enabled": false
    },
    "openai": {
      "enabled": false,
      "baseUrl": "https://api.openai.com/v1",
      "apiKey": "YOUR_OPENAI_API_KEY",
      "model": "gpt-4.1-mini"
    },
    "qwen": {
      "enabled": true,
      "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "apiKey": "YOUR_QIANWEN_API_KEY",
      "model": "qwen3.5-plus"
    }
  }
}
